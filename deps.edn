{:paths ["src"]
 ;; kotobase-server -- platform-independent XRPC handler + async/sync storage
 ;; bridge for a kotobase-peer-backed worker. No deploy surface, no
 ;; Cloudflare/R2/B2-specific code -- see README.md.
 ;; kotobase-peer pin: picks up arrangement's truncated-CBOR-input fix
 ;; (kotobase-peer#14, propagated from io-ipld/org-ietf-cbor) -- this
 ;; handler decodes untrusted bytes via kotobase-peer's engine calls
 ;; (hot-datoms/commit!/fold!), same vulnerable decode path.
 ;; kotobase-client pin: picks up kotobase.cid/did-key->ed25519-pub's
 ;; fail-closed fix (returns nil, not a throw, on malformed base58) --
 ;; kotobase.server.ipns requires kotobase.ipns (kotobase-client), whose
 ;; verify-head calls did-key->ed25519-pub directly to resolve the
 ;; signer's pubkey for every IPNS record signature check.
 :deps {io.github.kotoba-lang/kotobase-peer
        {:git/url "https://github.com/kotoba-lang/kotobase-peer.git"
         :git/sha "afe47e0990d1bc7ccfb53389d88cd0d6fb8068ac"}
        io.github.kotoba-lang/kotobase-client
        {:git/url "https://github.com/kotoba-lang/kotobase-client.git"
         :git/sha "a1799ffaa20557ba9b3eb956d4978c865734aa49"}}
 :aliases
 {:cljs {:extra-deps {thheller/shadow-cljs {:mvn/version "2.28.20"}}}
  :test-node
  {:extra-paths ["test" "../kotobase-peer/src"]
   :extra-deps {thheller/shadow-cljs {:mvn/version "2.28.20"}}}
  ;; clj-kondo as a Clojars lib (no Homebrew/system install needed).
  :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts ["-m" "clj-kondo.main" "--lint" "src" "test"
                     "--fail-level" "error"]}}}
